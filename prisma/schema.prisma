generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  PROCUREMENT_MANAGER
  WAREHOUSE_OFFICER
  ACCOUNTS_OFFICER
  SALES_OFFICER
  AUDITOR
}

enum PRStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  REJECTED
  CONVERTED
}

enum POStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  FULLY_RECEIVED
  CANCELLED
}

enum BillStatus {
  UNPAID
  PARTIALLY_PAID
  PAID
}

enum JobStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum SOStatus {
  DRAFT
  CONFIRMED
  INVOICED
  SHIPPED
  COMPLETED
  CANCELLED
}

enum InvStatus {
  DRAFT
  ISSUED
  PARTIALLY_COLLECTED
  COLLECTED
  CANCELLED
}

enum AccType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

enum VoucherType {
  JOURNAL
  RECEIPT
  PAYMENT
  EXPENSE
}

enum VoucherStat {
  DRAFT
  POSTED
  REVERSED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  POST
  APPROVE
  REJECT
}

model User {
  id            String     @id @default(cuid())
  name          String
  email         String     @unique
  emailVerified DateTime?
  image         String?
  password      String?
  role          UserRole   @default(SALES_OFFICER)
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  accounts      Account[]
  sessions      Session[]
  auditLogs     AuditLog[]
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  @@unique([identifier, token])
  @@map("verification_tokens")
}

model AuditLog {
  id        String      @id @default(cuid())
  userId    String
  action    AuditAction
  module    String
  recordId  String
  oldValue  Json?
  newValue  Json?
  reference String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id])
  @@index([module, recordId])
  @@map("audit_logs")
}

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
  @@map("categories")
}

model Unit {
  id        String    @id @default(cuid())
  name      String    @unique
  symbol    String    @unique
  createdAt DateTime  @default(now())
  products  Product[]
  @@map("units")
}

model Warehouse {
  id            String             @id @default(cuid())
  name          String             @unique
  address       String?
  isActive      Boolean            @default(true)
  createdAt     DateTime           @default(now())
  stocks        Stock[]
  grns          GoodsReceiptNote[]
  transfersFrom StockTransfer[]    @relation("FromWarehouse")
  transfersTo   StockTransfer[]    @relation("ToWarehouse")
  @@map("warehouses")
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contactName    String?
  phone          String?
  email          String?
  address        String?
  isActive       Boolean         @default(true)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
  supplierBills  SupplierBill[]
  @@map("suppliers")
}

model Customer {
  id          String       @id @default(cuid())
  name        String
  contactName String?
  phone       String?
  email       String?
  address     String?
  creditLimit Decimal      @default(0) @db.Decimal(18,2)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  salesOrders SalesOrder[]
  @@map("customers")
}

model Product {
  id             String                @id @default(cuid())
  sku            String                @unique
  name           String
  description    String?
  categoryId     String
  unitId         String
  costPrice      Decimal               @default(0) @db.Decimal(18,2)
  sellPrice      Decimal               @default(0) @db.Decimal(18,2)
  minStockLevel  Int                   @default(0)
  isActive       Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  category       Category              @relation(fields: [categoryId], references: [id])
  unit           Unit                  @relation(fields: [unitId], references: [id])
  stocks         Stock[]
  poItems        PurchaseOrderItem[]
  soItems        SalesOrderItem[]
  processInputs  ProcessingJobInput[]
  processOutputs ProcessingJobOutput[]
  adjustments    StockAdjustment[]
  transfers      StockTransfer[]
  @@map("products")
}

model Stock {
  id          String    @id @default(cuid())
  productId   String
  warehouseId String
  batchNo     String    @default("DEFAULT")
  quantity    Decimal   @default(0) @db.Decimal(18,3)
  expiryDate  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id])
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  @@unique([productId, warehouseId, batchNo])
  @@map("stocks")
}

model StockAdjustment {
  id          String   @id @default(cuid())
  productId   String
  warehouseId String
  batchNo     String?
  quantity    Decimal  @db.Decimal(18,3)
  reason      String
  adjustedBy  String
  adjustedAt  DateTime @default(now())
  product     Product  @relation(fields: [productId], references: [id])
  @@map("stock_adjustments")
}

model StockTransfer {
  id              String    @id @default(cuid())
  fromWarehouseId String
  toWarehouseId   String
  productId       String
  batchNo         String?
  quantity        Decimal   @db.Decimal(18,3)
  transferredBy   String
  transferredAt   DateTime  @default(now())
  notes           String?
  fromWarehouse   Warehouse @relation("FromWarehouse", fields: [fromWarehouseId], references: [id])
  toWarehouse     Warehouse @relation("ToWarehouse", fields: [toWarehouseId], references: [id])
  product         Product   @relation(fields: [productId], references: [id])
  @@map("stock_transfers")
}

model PurchaseRequisition {
  id          String                    @id @default(cuid())
  prNumber    String                    @unique
  status      PRStatus                  @default(DRAFT)
  requestedBy String
  approvedBy  String?
  approvedAt  DateTime?
  notes       String?
  createdAt   DateTime                  @default(now())
  updatedAt   DateTime                  @updatedAt
  items       PurchaseRequisitionItem[]
  @@map("purchase_requisitions")
}

model PurchaseRequisitionItem {
  id        String              @id @default(cuid())
  prId      String
  productId String
  quantity  Decimal             @db.Decimal(18,3)
  pr        PurchaseRequisition @relation(fields: [prId], references: [id], onDelete: Cascade)
  @@map("purchase_requisition_items")
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  poNumber     String              @unique
  supplierId   String
  status       POStatus            @default(DRAFT)
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  totalAmount  Decimal             @default(0) @db.Decimal(18,2)
  notes        String?
  createdBy    String
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  supplier     Supplier            @relation(fields: [supplierId], references: [id])
  items        PurchaseOrderItem[]
  grns         GoodsReceiptNote[]
  bills        SupplierBill[]
  @@map("purchase_orders")
}

model PurchaseOrderItem {
  id          String        @id @default(cuid())
  poId        String
  productId   String
  quantity    Decimal       @db.Decimal(18,3)
  unitPrice   Decimal       @db.Decimal(18,2)
  receivedQty Decimal       @default(0) @db.Decimal(18,3)
  po          PurchaseOrder @relation(fields: [poId], references: [id], onDelete: Cascade)
  product     Product       @relation(fields: [productId], references: [id])
  @@map("purchase_order_items")
}

model GoodsReceiptNote {
  id          String        @id @default(cuid())
  grnNumber   String        @unique
  poId        String
  warehouseId String
  receivedBy  String
  receivedAt  DateTime      @default(now())
  notes       String?
  po          PurchaseOrder @relation(fields: [poId], references: [id])
  warehouse   Warehouse     @relation(fields: [warehouseId], references: [id])
  items       GRNItem[]
  @@map("goods_receipt_notes")
}

model GRNItem {
  id        String           @id @default(cuid())
  grnId     String
  productId String
  batchNo   String?
  quantity  Decimal          @db.Decimal(18,3)
  unitPrice Decimal          @db.Decimal(18,2)
  grn       GoodsReceiptNote @relation(fields: [grnId], references: [id], onDelete: Cascade)
  @@map("grn_items")
}

model SupplierBill {
  id         String            @id @default(cuid())
  billNumber String            @unique
  supplierId String
  poId       String?
  amount     Decimal           @db.Decimal(18,2)
  paidAmount Decimal           @default(0) @db.Decimal(18,2)
  status     BillStatus        @default(UNPAID)
  dueDate    DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  supplier   Supplier          @relation(fields: [supplierId], references: [id])
  po         PurchaseOrder?    @relation(fields: [poId], references: [id])
  payments   SupplierPayment[]
  @@map("supplier_bills")
}

model SupplierPayment {
  id        String       @id @default(cuid())
  billId    String
  amount    Decimal      @db.Decimal(18,2)
  paidAt    DateTime     @default(now())
  paidBy    String
  reference String?
  bill      SupplierBill @relation(fields: [billId], references: [id])
  @@map("supplier_payments")
}

model ProcessingJob {
  id        String                @id @default(cuid())
  jobNumber String                @unique
  status    JobStatus             @default(PLANNED)
  startDate DateTime?
  endDate   DateTime?
  notes     String?
  createdBy String
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt
  inputs    ProcessingJobInput[]
  outputs   ProcessingJobOutput[]
  @@map("processing_jobs")
}

model ProcessingJobInput {
  id        String        @id @default(cuid())
  jobId     String
  productId String
  batchNo   String?
  quantity  Decimal       @db.Decimal(18,3)
  job       ProcessingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  product   Product       @relation(fields: [productId], references: [id])
  @@map("processing_job_inputs")
}

model ProcessingJobOutput {
  id        String        @id @default(cuid())
  jobId     String
  productId String
  batchNo   String?
  quantity  Decimal       @db.Decimal(18,3)
  wastage   Decimal       @default(0) @db.Decimal(18,3)
  job       ProcessingJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  product   Product       @relation(fields: [productId], references: [id])
  @@map("processing_job_outputs")
}

model SalesOrder {
  id         String           @id @default(cuid())
  soNumber   String           @unique
  customerId String
  status     SOStatus         @default(DRAFT)
  currency   String           @default("BDT")
  fxRate     Decimal          @default(1) @db.Decimal(18,6)
  orderDate  DateTime         @default(now())
  notes      String?
  createdBy  String
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  customer   Customer         @relation(fields: [customerId], references: [id])
  items      SalesOrderItem[]
  invoices   Invoice[]
  @@map("sales_orders")
}

model SalesOrderItem {
  id        String     @id @default(cuid())
  soId      String
  productId String
  quantity  Decimal    @db.Decimal(18,3)
  unitPrice Decimal    @db.Decimal(18,2)
  so        SalesOrder @relation(fields: [soId], references: [id], onDelete: Cascade)
  product   Product    @relation(fields: [productId], references: [id])
  @@map("sales_order_items")
}

model Invoice {
  id          String       @id @default(cuid())
  invoiceNo   String       @unique
  soId        String
  status      InvStatus    @default(DRAFT)
  currency    String       @default("BDT")
  fxRate      Decimal      @default(1) @db.Decimal(18,6)
  totalAmount Decimal      @db.Decimal(18,2)
  collected   Decimal      @default(0) @db.Decimal(18,2)
  dueDate     DateTime?
  issuedAt    DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  so          SalesOrder   @relation(fields: [soId], references: [id])
  collections Collection[]
  shipments   Shipment[]
  @@map("invoices")
}

model ExchangeRate {
  id           String   @id @default(cuid())
  fromCurrency String
  toCurrency   String   @default("BDT")
  rate         Decimal  @db.Decimal(18,6)
  rateDate     DateTime
  source       String?
  createdAt    DateTime @default(now())
  @@unique([fromCurrency, toCurrency, rateDate])
  @@map("exchange_rates")
}

model Shipment {
  id               String   @id @default(cuid())
  shipmentNo       String   @unique
  invoiceId        String
  shippedAt        DateTime @default(now())
  shippedBy        String

  // Export Specific Fields
  containerNo      String?
  sealNo           String?
  vesselName       String?
  voyageNo         String?
  portOfLoading    String?  @default("Chittagong, Bangladesh")
  portOfDischarge  String?
  finalDestination String?
  billOfLadingNo   String?
  grossWeight      Decimal? @db.Decimal(18,3)
  netWeight        Decimal? @db.Decimal(18,3)

  notes            String?
  invoice          Invoice  @relation(fields: [invoiceId], references: [id])
  @@map("shipments")
}

model Collection {
  id          String   @id @default(cuid())
  invoiceId   String
  amount      Decimal  @db.Decimal(18,2)
  collectedAt DateTime @default(now())
  collectedBy String
  reference   String?
  invoice     Invoice  @relation(fields: [invoiceId], references: [id])
  @@map("collections")
}

model AccountHead {
  id        String         @id @default(cuid())
  code      String         @unique
  name      String
  type      AccType
  parentId  String?
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  parent    AccountHead?   @relation("AccountTree", fields: [parentId], references: [id])
  children  AccountHead[]  @relation("AccountTree")
  entries   VoucherEntry[]
  @@map("account_heads")
}

model Voucher {
  id          String         @id @default(cuid())
  voucherNo   String         @unique
  type        VoucherType
  status      VoucherStat    @default(DRAFT)
  date        DateTime       @default(now())
  description String?
  totalDebit  Decimal        @default(0) @db.Decimal(18,2)
  totalCredit Decimal        @default(0) @db.Decimal(18,2)
  createdBy   String
  postedBy    String?
  postedAt    DateTime?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  entries     VoucherEntry[]
  @@map("vouchers")
}

model VoucherEntry {
  id            String      @id @default(cuid())
  voucherId     String
  accountHeadId String
  debit         Decimal     @default(0) @db.Decimal(18,2)
  credit        Decimal     @default(0) @db.Decimal(18,2)
  narration     String?
  voucher       Voucher     @relation(fields: [voucherId], references: [id], onDelete: Cascade)
  accountHead   AccountHead @relation(fields: [accountHeadId], references: [id])
  @@map("voucher_entries")
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  TERMINATED
  ON_LEAVE
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  ON_LEAVE
}

enum PayrollStatus {
  DRAFT
  PROCESSED
  PAID
  CANCELLED
}

model Employee {
  id              String         @id @default(cuid())
  employeeId      String         @unique
  name            String
  email           String?        @unique
  phone           String?
  designation     String
  department      String
  joiningDate     DateTime
  basicSalary     Decimal        @db.Decimal(18,2)
  status          EmployeeStatus @default(ACTIVE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  attendances     Attendance[]
  salarySlips     SalarySlip[]
  @@map("employees")
}

model Attendance {
  id          String           @id @default(cuid())
  employeeId  String
  date        DateTime
  checkIn     DateTime?
  checkOut    DateTime?
  status      AttendanceStatus @default(PRESENT)
  notes       String?
  employee    Employee         @relation(fields: [employeeId], references: [id])
  @@unique([employeeId, date])
  @@map("attendances")
}

model Payroll {
  id          String        @id @default(cuid())
  month       Int
  year        Int
  status      PayrollStatus @default(DRAFT)
  processedAt DateTime?
  processedBy String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  salarySlips SalarySlip[]
  @@unique([month, year])
  @@map("payrolls")
}

model SalarySlip {
  id            String    @id @default(cuid())
  payrollId     String
  employeeId    String
  basicSalary   Decimal   @db.Decimal(18,2)
  allowances    Decimal   @default(0) @db.Decimal(18,2)
  deductions    Decimal   @default(0) @db.Decimal(18,2)
  netSalary     Decimal   @db.Decimal(18,2)
  paymentStatus String    @default("UNPAID")
  paidAt        DateTime?
  payroll       Payroll   @relation(fields: [payrollId], references: [id])
  employee      Employee  @relation(fields: [employeeId], references: [id])
  @@unique([payrollId, employeeId])
  @@map("salary_slips")
}

enum BankAccountType {
  CASH
  SAVINGS
  CURRENT
  CREDIT_CARD
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  TRANSFER
}

model BankAccount {
  id            String            @id @default(cuid())
  name          String
  accountNumber String?           @unique
  bankName      String?
  branchName    String?
  type          BankAccountType   @default(CURRENT)
  balance       Decimal           @default(0) @db.Decimal(18,2)
  isActive      Boolean           @default(true)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  transactions  BankTransaction[]
  @@map("bank_accounts")
}

model BankTransaction {
  id           String          @id @default(cuid())
  accountId    String
  type         TransactionType
  amount       Decimal         @db.Decimal(18,2)
  date         DateTime        @default(now())
  reference    String?
  description  String?
  isReconciled Boolean         @default(false)
  reconciledAt DateTime?
  createdBy    String
  account      BankAccount     @relation(fields: [accountId], references: [id])
  @@map("bank_transactions")
}

enum ExpenseStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  PAID
}

model ExpenseCategory {
  id        String         @id @default(cuid())
  name      String         @unique
  isActive  Boolean        @default(true)
  createdAt DateTime       @default(now())
  claims    ExpenseClaim[]
  @@map("expense_categories")
}

model ExpenseClaim {
  id          String          @id @default(cuid())
  claimNumber String          @unique
  categoryId  String
  amount      Decimal         @db.Decimal(18,2)
  date        DateTime        @default(now())
  description String?
  status      ExpenseStatus   @default(DRAFT)
  claimedBy   String
  approvedBy  String?
  approvedAt  DateTime?
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  category    ExpenseCategory @relation(fields: [categoryId], references: [id])
  @@map("expense_claims")
}

model CompanySetting {
  id                   String   @id @default(cuid())
  companyName          String   @default("Aira Aqua")
  legalName            String?
  binNumber            String?
  tin                  String?
  vatRegNo             String?
  address              String?
  phone                String?
  email                String?
  website              String?
  logoUrl              String?
  baseCurrency         String   @default("BDT")
  fiscalYearStartMonth Int      @default(7)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  @@map("company_settings")
}
